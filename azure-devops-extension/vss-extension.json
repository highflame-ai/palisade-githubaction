{
  "manifestVersion": 1,
  "id": "palisade-security",
  "name": "Palisade Security Scanner",
  "version": "1.0.0",
  "publisher": "getjavelin",
  "description": "Run Palisade security scans in Azure DevOps pipelines",
   "overview": {
    "path": "azure-devops-extension/README.md"
  },
  "targets": [
    { "id": "Microsoft.VisualStudio.Services" }
  ],
  "categories": ["Azure Pipelines"],
    "tags": [
    "security",
    "devsecops",
    "ci",
    "cd",
    "scanner",
    "vulnerability"
  ],
  "files": [
    { "path": "task" }
  ],
  "contributions": [
    {
      "id": "palisade-task",
      "type": "ms.vss-distributed-task.task",
      "targets": [
        "ms.vss-distributed-task.tasks"
      ],
      "properties": {
        "name": "task"
      }
    }
  ]
}
